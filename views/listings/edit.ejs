<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wanderLust</title>
</head>

<body>
    <h3>Edit Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input name="listing[title]" value="<%= listing.title  %>" type="text" />
        <br><br>
        <textarea rows="6" cols="55" name="listing[description]"><%= listing.description  %></textarea>
        <br><br>
        <input name="listing[image]" value="<%= listing.image  %>" type="text" />
        <br><br>
        <input name="listing[price]" value="<%= listing.price  %>" type="number" />
        <br><br>
        <input name="listing[country]" value="<%= listing.location  %>" type="text" />
        <br><br>
        <input name="listing[location]" value="<%= listing.country  %>" type="text" />
        <br><br>
        <button>Edit</button>
    </form>    
</body>

</html>