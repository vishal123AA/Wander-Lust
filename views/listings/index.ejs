<% layout("/layouts/boilerplate.ejs") %>

    <h3>All listings</h3>
    <form  method="get" action="/listings/new">
        <button>Create new Listing</button>
    </form>
    <ul>
        <% for(let listing of allListings){ %>
            <li><a href="/listings/<%= listing._id%>"><%= listing.title %> </a></li>
        <%}%>
    </ul>
     