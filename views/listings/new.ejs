<% layout("/layouts/boilerplate.ejs") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>New Listing</h3>
            <br>
            <form method="POST" action="/listings">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" id="title" class="form-control" placeholder="Add a Cachy Title"
                        type="text" />
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea rows="6" cols="55" name="listing[description]" id="description" class="form-control"
                        placeholder="enter description"></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image Link</label>
                    <input name="listing[image]" id="image" class="form-control" placeholder="enter image URL/Link"
                        type="text" />
                </div>
                <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input name="listing[price]" id="price" class="form-control" placeholder="1500"
                        type="number" />
                </div>
                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" id="country" class="form-control" placeholder="India"
                        type="text" />
                </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" id="location" class="form-control" placeholder="Manali,Himachal Pardesh"
                        type="text" />
                </div>
                <button class="btn btn-dark add-btn mt-3">Add</button>
                <br><br>
        </div>
    </div>