<% layout("/layouts/boilerplate") %>
<div class="row mt-3 justify-content-center">
    <div class=" col-lg-8 col-md-10 col-12 mb-2">
        <h3>Listing Details :</h3>
    </div>

    <div class="card  col-lg-8 col-md-10 col-12 mb-3 show-card">
        <img src="<%= listing.image %>" class="card-img-top show-img" alt="Listing Image">
        <div class="card-body">
            <p class="card-text mt-3">
                <b><%= listing.title %></b><br><br>
                <%= listing.description %> <br><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %> <br>
                <%= listing.location %><br>
                <%= listing.country %>
            </p>
        </div>
    </div>
    
    <div class=" col-lg-8 col-md-10 col-12 btns mb-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn me-3">Edit</a>
        
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark">Delete</button>
        </form>
    </div>
</div>