<% layout("/layouts/boilerplate") %>
    <div class="row mt-3 justify-content-center">
        <div class=" col-lg-8 col-md-10 col-sm-12 mb-2">
            <h3><b style="margin-left: 1rem;"><%= listing.title %></b></h3>
        </div>

        <div class="card  col-lg-8 col-md-10 col-sm-12 mb-3 show-card">
            <img src="<%= listing.image %>" class="card-img-top show-img" alt="Listing Image">

            <div class="card-body">
                <p class="card-text mt-3">Owned by <i><%= listing.owner.username %></i></p>
                <p class="card-text mt-3"><%= listing.description %></p>
                <!-- <b><%= listing.title %></b> -->
                <p class="card-text mt-3">&#8377;<%= listing.price.toLocaleString("en-IN") %></p>
                <p class="card-text mt-3"><%= listing.location %></p>
                <p class="card-text mt-3"><%= listing.country %></p>
            </div>
        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
          <div class=" col-lg-8 col-md-10 col-sm-12 btns mb-3">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn me-3">Edit</a>

              <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                  <button class="btn btn-dark">Delete</button>
              </form>
          </div>
        <% } %>

        <div class="col-lg-8 col-sm-12 col-md-10">
            <hr>
            <% if(currUser){ %>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" class="mb-3 mt-3 needs-validation" novalidate method="post">

               <div class="mb-1">
                <label for="rating" class="form-label">Rating</label>
                  <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                  </fieldset>
               </div> 
                
                <div>
                    <label for="comment" class="form-label">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                        required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please write an comment for adding reviews
                    </div>
                </div>

                <br>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
            <hr>
            <% } %>

            <h3 class="mb-3"> All Reviews </h3>
            <div class="row">
                <%for(review of listing.reviews){%>
                    <!-- <% console.log(review.author)  %> -->

                  <div class="review-card col-12 col-md-5 mb-3 d-flex flex-column">  
                     <div class="card-body mb-2">
                        <h5 class="card-title">@<%=review.author.username%></h5><br>
                        <p class="starability-result" data-rating="<%= review.rating %>"></p>                  
                        <p class="card-text">  <%=review.comment %></p>
                     </div>

                     <% if(currUser && review.author._id.equals(currUser._id)){ %>
                     <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-1 mt-auto">
                        <button class="btn btn-sm btn-dark">Delete</button>
                     </form>
                     <% } %>

                   </div> 
                <%}%>
            </div>
        </div>
    </div>