<% layout("/layouts/boilerplate.ejs") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>Signup User</h3>
            <br>
            <form method="POST" action="/signUp" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input name="user[username]" id="username" class="form-control" placeholder="Enter Username"
                        type="text"  required />
                    <div class="valid-feedback">
                        Okay
                    </div>
                    <div class="invalid-feedback">
                        Username is required
                    </div>    
                </div>
                <br>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input name="user[email]" id="email" class="form-control" placeholder="Enter Email"
                        type="email" required />
                    <div class="valid-feedback">
                        Okay
                    </div>
                    <div class="invalid-feedback">
                       Valid Email is required
                    </div>    
                </div>
                <br>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="user[password]" id="password" class="form-control" placeholder="Enter Password"
                        type="password"  required />
                    <div class="valid-feedback">
                        Okay
                    </div>
                    <div class="invalid-feedback">
                        Password min length 6
                    </div>    
                </div>
                <br>
                <button class="btn btn-success">SignUp</button>
                <br><br>
            </form>    
        </div>
    </div>        